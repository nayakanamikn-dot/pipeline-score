# ══════════════════════════════════════════
# Pipeline Score — Environment Variables
# ══════════════════════════════════════════
# Copy this file to .env and fill in your values.
# These are injected at build time or via Vercel dashboard.

# ── ANALYTICS ──
# Google Analytics Measurement ID (optional)
GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ── CONTACT ──
# Your booking URL (Calendly, Cal.com, etc.)
BOOKING_URL=https://calendly.com/your-link

# Your email for the CTA
CONTACT_EMAIL=nayak.anamik.n@gmail.com

# ── SITE ──
# Production URL (used for OG tags and canonical)
SITE_URL=https://pipelinescore.vercel.app

# ── INTEGRATIONS (future) ──
# Webhook URL for lead capture (Zapier, Make, n8n)
WEBHOOK_URL=

# HubSpot API key for CRM integration
HUBSPOT_API_KEY=

# GoHighLevel API key
GHL_API_KEY=
